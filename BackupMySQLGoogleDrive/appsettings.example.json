{
  "MySql": {
    "ConnectionString": "<YOUR_MYSQL_CONNECTION_STRING>",
    "DatabaseName": "<YOUR_DATABASE_NAME>"
  },
  "GoogleDrive": {
    "ClientId": "<YOUR_GOOGLE_OAUTH_CLIENT_ID>",
    "ClientSecret": "<YOUR_GOOGLE_OAUTH_CLIENT_SECRET>",
    "FolderId": "<YOUR_DRIVE_FOLDER_ID>",
    "SupportsSharedDrives": true,
    "ApplicationName": "Backup MySQL To Google Drive"
  },
  "Backup": {
    "TempDirectory": "C:\\Temp\\BackupMySQLGoogleDrive",
    "FileNamePrefix": "backup",
    "Compress": true
  },
  "Rotation": {
    "KeepLastN": null,
    "MaxAgeDays": null
  },
  "Notifications": {
    "WebhookUrl": "<YOUR_WEBHOOK_URL>",
    "NotifyOnSuccess": false
  }
}
